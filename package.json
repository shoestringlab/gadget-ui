{
  "name": "gadget-ui",
  "version": "12.2.0",
  "description": "JavaScript UI and data binding library",
  "repository": {
    "type": "git",
    "url": "https://github.com/shoestringlab/gadget-ui.git"
  },
  "bugs": {
    "url": "https://github.com/shoestringlab/gadget-ui/issues"
  },
  "homepage": "https://github.com/shoestringlab/gadget-ui#readme",
  "keywords": [
    "JavaScript",
    "UI",
    "data binding"
  ],
  "main": "./dist/gadget-ui.js",
  "module": "./dist/gadget-ui.es.js",
  "exports": {
    ".": {
      "import": "./dist/gadget-ui.es.js",
      "require": "./dist/gadget-ui.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:js": "rollup -c",
    "build:css": "grunt concat:css",
    "build": "npm run build:js && npm run build:css",
    "lint": "grunt jshint"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "claude": "^0.1.1",
    "concat-files": "^0.1.1",
    "concat-map": "0.0.1",
    "cuid": "*",
    "express": "^4.18.2",
    "grunt": "^1.5.3",
    "grunt-cli": "^1.5.0",
    "grunt-contrib-concat": "^1.0.1",
    "grunt-contrib-jshint": "^3.2.0",
    "grunt-contrib-qunit": "^3.1.0",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-newer": "^1.3.0",
    "grunt-terser": "^2.0.0",
    "load-grunt-config": "^4.0.1",
    "load-grunt-tasks": "^4.0.0",
    "mariadb": "^2.2.0",
    "minimist": "^1.2.7",
    "modlazy": "^1.0.0",
    "open-iconic": "^1.1.1",
    "rollup": "^4.60.0",
    "trim-newlines": "^4.0.2",
    "ws": "^8.12.0"
  },
  "author": "Robert Munn <robert@robertmunn.com>",
  "license": "MIT",
  "dependencies": {
    "feather-icons": "^4.29.0",
    "velocity-animate": "^2.0.6"
  }
}
